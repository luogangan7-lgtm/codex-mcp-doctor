{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${PLUGIN_ROOT:-$HOME/.codex/plugins/codex-mcp-doctor}/scripts/doctor.py\" --json --timeout 5 2>/dev/null || true",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${PLUGIN_ROOT:-$HOME/.codex/plugins/codex-mcp-doctor}/scripts/doctor.py\" --json --timeout 5 --quiet 2>/dev/null || true",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
